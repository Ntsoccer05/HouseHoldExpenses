# ECS/RDS スケジュール停止 Lambda のデプロイ設定
# このファイルをコピーして .env.scheduler を作成してください
# cp .env.scheduler.example .env.scheduler

# ECS クラスター名 (AWSコンソール → ECS → クラスター)
ECS_CLUSTER=your-cluster-name

# ECS サービス名 (クラスター内のサービス名)
ECS_SERVICE=your-service-name

# RDS DB識別子 (AWSコンソール → RDS → データベース → DB識別子)
RDS_INSTANCE_ID=your-db-identifier

# AWSリージョン
AWS_REGION=ap-northeast-1
